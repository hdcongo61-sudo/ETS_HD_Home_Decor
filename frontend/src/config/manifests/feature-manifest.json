{
  "$schema": "./feature-manifest.schema.json",
  "version": "1.0.0",
  "description": "Feature manifest for ETS HD Home Decor SaaS. Toggle or plan features without code changes.",
  "features": [
    {
      "id": "sales",
      "name": "Ventes",
      "enabled": true,
      "route": "/sales",
      "description": "Gestion des ventes, paiements, rappels et livraisons",
      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "bank",
      "name": "Caisse",
      "enabled": true,
      "route": "/bank",
      "description": "Transactions bancaires et trésorerie",
      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "clients",
      "name": "Clients",
      "enabled": true,
      "route": "/clients",
      "description": "Répertoire clients et tableaux de bord",
      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "products",
      "name": "Produits",
      "enabled": true,
      "route": "/products",
      "description": "Catalogue, stock, fournisseurs, entrepôts",
      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "product-dashboard",
      "name": "Dashboard Produits",
      "enabled": true,
      "route": "/product-dashboard",
      "description": "Analyses produits (jamais vendus, meilleures ventes, stock critique)",
      "adminOnly": true,
      "mobilePriority": false
