      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "inventory-alerts",
      "name": "Alertes Stock",
      "enabled": false,
      "route": "/settings/alerts",
      "description": "Seuils et notifications automatiques (future)",
      "adminOnly": true,
      "mobilePriority": true
    },
    {
      "id": "multi-tenant",
      "name": "Multi-établissements",
      "enabled": false,
      "route": null,
      "description": "Plusieurs points de vente / filiales (future)",
      "adminOnly": true,
      "mobilePriority": false
    },
    {
      "id": "api-keys",
      "name": "Clés API",
      "enabled": false,
      "route": "/settings/api",
      "description": "Clés API pour intégrations tierces (future)",
      "adminOnly": true,
      "mobilePriority": false
    }
