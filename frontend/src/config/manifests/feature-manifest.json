    {
      "id": "employees",
      "name": "Employés",
      "enabled": true,
      "route": "/employees",
      "description": "Fiches employés, paie, avances",
      "adminOnly": false,
      "mobilePriority": true
    },
    {
      "id": "expenses",
      "name": "Dépenses",
      "enabled": true,
      "route": "/expenses",
      "description": "Suivi des dépenses",
      "adminOnly": true,
      "mobilePriority": true
    },
    {
      "id": "user-management",
      "name": "Gestion Utilisateurs",
      "enabled": true,
      "route": "/admin/users",
      "description": "Création et gestion des comptes utilisateurs",
      "adminOnly": true,
      "mobilePriority": false
